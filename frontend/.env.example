# Render / local API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# https://cloud.walletconnect.com — optional; without it, MetaMask / injected wallets still work
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Home hero media (optional)
# If you don't set these, the app uses a default Unsplash crypto-themed image.
# NEXT_PUBLIC_HERO_IMAGE_URL=https://images.unsplash.com/... 
# NEXT_PUBLIC_HERO_VIDEO_URL=/hero-banner.mp4

PORT=4000
NODE_ENV=development

# Same value must be set in Convex Dashboard → Settings → Environment variables as BACKEND_SECRET
BACKEND_SECRET=generate_a_long_random_string_min_32_chars

JWT_SECRET=another_long_random_secret_for_access_tokens
# Optional: separate secret for short-lived 2FA step-up tokens
# JWT_2FA_SECRET=

# https://xxx.convex.cloud from `npx convex dev` or Convex dashboard
CONVEX_URL=

# 32-byte key as 64 hex characters (openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=

# Comma-separated origins for browser clients (production + preview URLs)
CORS_ORIGIN=http://localhost:3000

# Used in registration response for email verification links
PUBLIC_APP_URL=http://localhost:3000

# Optional tuning
# BCRYPT_ROUNDS=12
# ACCESS_TOKEN_TTL_SEC=604800
# TWO_FA_TOKEN_TTL_SEC=300
